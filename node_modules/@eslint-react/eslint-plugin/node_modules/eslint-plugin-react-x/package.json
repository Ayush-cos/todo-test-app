{
  "name": "eslint-plugin-react-x",
  "version": "5.8.10",
  "description": "A set of composable ESLint rules for libraries and frameworks that use React as a UI runtime.",
  "keywords": [
    "react",
    "eslint",
    "eslint-react",
    "eslint-plugin",
    "eslint-plugin-react-x"
  ],
  "homepage": "https://github.com/Rel1cx/eslint-react",
