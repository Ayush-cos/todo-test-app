    "@typescript-eslint/type-utils": "^8.60.0",
    "@typescript-eslint/types": "^8.60.0",
    "@typescript-eslint/typescript-estree": "^8.60.0",
    "@typescript-eslint/utils": "^8.60.0",
    "compare-versions": "^6.1.1",
    "string-ts": "^2.3.1",
    "ts-api-utils": "^2.5.0",
    "ts-pattern": "^5.9.0",
    "@eslint-react/ast": "5.8.10",
    "@eslint-react/core": "5.8.10",
    "@eslint-react/eslint": "5.8.10",
    "@eslint-react/jsx": "5.8.10",
    "@eslint-react/shared": "5.8.10",
    "@eslint-react/var": "5.8.10"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "dedent": "^1.7.2",
    "eslint": "^10.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "^0.22.1",
    "tsl": "^1.0.30",
    "tsl-dx": "^0.12.1",
    "typescript": "5.9.3",
    "@local/eff": "0.0.0",
    "@local/configs": "0.0.0"
  },
  "peerDependencies": {
    "eslint": "^10.3.0",
    "typescript": "*"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "inlinedDependencies": {
    "@local/eff": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "lint:publish": "publint",
    "lint:ts": "tsl"
